  dialogueText: {fileID: 1554502834}
  characterImage: {fileID: 1554502833}
  voiceSource: {fileID: 1822192645}
  lines:
  - speakerName: "\uC774\uB2E4 \uD39C"
    dialogue: "\uC654\uAD70\uC694."
    characterSprite: {fileID: 21300000, guid: 1a0a4b2c72811a945b126e1d9c0d8e07, type: 3}
    voiceClip: {fileID: 0}
  - speakerName: "\uC774\uB2E4 \uD39C"
    dialogue: "\uC624\uB798 \uAE30\uB2E4\uB838\uC5B4\uC694."
    characterSprite: {fileID: 21300000, guid: 1a0a4b2c72811a945b126e1d9c0d8e07, type: 3}
    voiceClip: {fileID: 0}
  - speakerName: "\uC774\uB2E4 \uD39C"
    dialogue: "\uC190\uB140\uAC00 \uC788\uC5B4\uC694. \uC5EC\uC12F \uC0B4. \uC0AC\uACE0\uB85C
      \uB450 \uB2E4\uB9AC\uB97C \uC783\uC5C8\uC9C0\uC694."
    characterSprite: {fileID: 21300000, guid: 1a0a4b2c72811a945b126e1d9c0d8e07, type: 3}
    voiceClip: {fileID: 0}
  - speakerName: "\uC774\uB2E4 \uD39C"
    dialogue: "\uC218\uC233\uBE44\uAC00 \uC5C6\uC5C8\uB294\uB370... THE HOUSE \uC0AC\uB78C\uC774
      \uB9D0\uD588\uC5B4\uC694.\nLUX\uB97C \uBE4C\uB9AC\uBA74 \uB41C\uB2E4\uACE0.
      \uB450 \uBC88\uC774\uBA74 \uCDA9\uBD84\uD558\uB2E4\uACE0. "
    characterSprite: {fileID: 21300000, guid: 1a0a4b2c72811a945b126e1d9c0d8e07, type: 3}
    voiceClip: {fileID: 0}
  - speakerName: "\uC774\uB2E4 \uD39C"
    dialogue: "\uB450 \uBC88\uC73C\uB85C \uBAA8\uC790\uB790\uC5B4\uC694. \uADF8\uB798\uC11C
      \uC138 \uBC88. \uB124 \uBC88. \uB2E4\uC12F \uBC88."
    characterSprite: {fileID: 21300000, guid: 1a0a4b2c72811a945b126e1d9c0d8e07, type: 3}
    voiceClip: {fileID: 0}
  - speakerName: "\uC774\uB2E4 \uD39C"
    dialogue: "\uC218\uC220\uC740 "
    characterSprite: {fileID: 21300000, guid: 1a0a4b2c72811a945b126e1d9c0d8e07, type: 3}
    voiceClip: {fileID: 0}
  - speakerName: "\uC774\uB2E4 \uD39C"
    dialogue: "\uAD1C\uCC2E\uC544\uC694. \uD574\uC694. "
    characterSprite: {fileID: 21300000, guid: 1a0a4b2c72811a945b126e1d9c0d8e07, type: 3}
    voiceClip: {fileID: 0}
  - speakerName: "17\uAD6C\uC5ED \uACBD\uBE44"
    dialogue: "\uBA48\uCDB0! \uBA48\uCD94\uB780 \uB9D0\uC774\uC57C! "
    characterSprite: {fileID: 21300000, guid: 1a0a4b2c72811a945b126e1d9c0d8e07, type: 3}
    voiceClip: {fileID: 0}
  - speakerName: "17\uAD6C\uC5ED \uACBD\uBE44"
    dialogue: 
    characterSprite: {fileID: 21300000, guid: 1a0a4b2c72811a945b126e1d9c0d8e07, type: 3}
