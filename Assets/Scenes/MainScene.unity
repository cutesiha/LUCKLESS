        characterSprite: {fileID: 0}
        voiceClip: {fileID: 0}
  - speakerName: ???
    dialogue: "\uD589\uC6B4\uC740... \uBB3C\uAC74\uC774\uC5D0\uC694.\n\uC0AC\uACE0\uD314
      \uC218 \uC788\uB294. \uD6D4\uCE60 \uC218\uB3C4 \uC788\uB294."
    characterSprite: {fileID: 0}
