        voiceClip: {fileID: 0}
  - speakerName: ???
    dialogue: "\uC804\uBD80 \uD2C0\uB838\uC5B4\uC694."
    characterSprite: {fileID: 0}
    voiceClip: {fileID: 8300000, guid: 4fb1bab7fa604384c85795c131114aa5, type: 3}
