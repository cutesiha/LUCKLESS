        voiceClip: {fileID: 0}
  - speakerName: ???
    dialogue: "\uB178\uB825\uC774 \uBD80\uC871\uD55C \uC0AC\uB78C\uB4E4\uC774 \uD558\uB294
      \uBCC0\uBA85\uC774\uB77C\uACE0\uB3C4 \uD558\uACE0.\n\uC2E0\uC774 \uC900 \uC120\uBB3C\uC774\uB77C\uACE0
      \uD558\uB294 \uC0AC\uB78C\uB3C4 \uC788\uC5B4\uC694."
