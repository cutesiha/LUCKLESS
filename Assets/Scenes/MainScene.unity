    dialogue: "\uBD80\uC790\uB4E4\uC740 \uC0AC\uC694. \uB354 \uC798 \uC0B4\uAE30
      \uC704\uD574\uC11C. "
    characterSprite: {fileID: 21300000, guid: 8af7b5ad94be1ba41b30a074b4655a52, type: 3}
