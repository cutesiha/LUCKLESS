        voiceClip: {fileID: 0}
  - speakerName: ???
    dialogue: "\uADF8\uB9AC\uACE0 \u2014 \uBE7C\uC557\uC744 \uC218\uB3C4 \uC788\uB294."
    characterSprite: {fileID: 0}
