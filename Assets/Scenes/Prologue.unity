  - canvasName: Canvas 3
    canvasGroup: {fileID: 1110624431}
    lines:
    - speakerName: "\uD558\uC6B0\uC2A4 \uB9C8\uC2A4\uD130"
      dialogue: "\uC911\uAC1C\uD558\uC8E0! THE HOUSE! \uC774 \uC138\uACC4 LUX\uC758
