        characterSprite: {fileID: 0}
        voiceClip: {fileID: 0}
  - speakerName: "\uD558\uC6B0\uC2A4 \uB9C8\uC2A4\uD130"
    dialogue: "\uB0B4\uAC00 \uB2F9\uC2E0\uC744 \uC5EC\uAE30\uB85C \uBD80\uB978 \uC774\uC720\uB97C
      \uC124\uBA85\uD574\uC904\uAC8C\uC694."
    characterSprite: {fileID: 21300000, guid: 8af7b5ad94be1ba41b30a074b4655a52, type: 3}
    voiceClip: {fileID: 8300000, guid: 79d733cdeec28c044961eb9e1c86efb0, type: 3}
    hasChoices: 0
    choices:
    - choiceText: 
      responseLines:
      - speakerName: 
        dialogue: 
        characterSprite: {fileID: 0}
        voiceClip: {fileID: 0}
    - choiceText: 
      responseLines:
      - speakerName: 
        dialogue: 
        characterSprite: {fileID: 0}
        voiceClip: {fileID: 0}
    - choiceText: 
      responseLines:
      - speakerName: 
        dialogue: 
        characterSprite: {fileID: 0}
        voiceClip: {fileID: 0}
  - speakerName: "\uD558\uC6B0\uC2A4 \uB9C8\uC2A4\uD130"
    dialogue: "\uC778\uAC04\uC758 \uB1CC \uC548\uC5D0\uB294 '\uD3EC\uB974\uD22C\uB098
      \uCF54\uC5B4'\uB77C\uB294 \uC2E0\uACBD\uB9DD\uC774 \uC788\uC5B4\uC694.\n\uC5EC\uAE30\uC11C
      \uB098\uC624\uB294 \uC2E0\uD638\uAC00 \uD655\uB960\uC744 \uBE44\uD2C0\uC8E0."
    characterSprite: {fileID: 21300000, guid: 8af7b5ad94be1ba41b30a074b4655a52, type: 3}
    voiceClip: {fileID: 8300000, guid: 974da0633aec295478d17798c41c0ec9, type: 3}
    hasChoices: 0
    choices:
    - choiceText: 
      responseLines:
      - speakerName: 
        dialogue: 
        characterSprite: {fileID: 0}
        voiceClip: {fileID: 0}
    - choiceText: 
      responseLines:
      - speakerName: 
        dialogue: 
        characterSprite: {fileID: 0}
        voiceClip: {fileID: 0}
    - choiceText: 
      responseLines:
      - speakerName: 
        dialogue: 
        characterSprite: {fileID: 0}
        voiceClip: {fileID: 0}
  - speakerName: "\uD558\uC6B0\uC2A4 \uB9C8\uC2A4\uD130"
    dialogue: "\uCD1D\uC54C\uC774 \uBE57\uB098\uAC00\uACE0, \uC0AC\uC5C5\uC774 \uC798
      \uD480\uB9AC\uACE0. \uC6B0\uB9AC\uB294 \uADF8\uAC78 \uD589\uC6B4\uC774\uB77C\uACE0
      \uBD80\uB974\uC796\uC544\uC694."
    characterSprite: {fileID: 21300000, guid: 8af7b5ad94be1ba41b30a074b4655a52, type: 3}
    voiceClip: {fileID: 8300000, guid: a06613cc366e2ed438e816d9dedce358, type: 3}
    hasChoices: 0
    choices:
    - choiceText: 
      responseLines:
      - speakerName: 
        dialogue: 
        characterSprite: {fileID: 0}
        voiceClip: {fileID: 0}
    - choiceText: 
      responseLines:
      - speakerName: 
        dialogue: 
        characterSprite: {fileID: 0}
        voiceClip: {fileID: 0}
    - choiceText: 
      responseLines:
      - speakerName: 
        dialogue: 
        characterSprite: {fileID: 0}
        voiceClip: {fileID: 0}
  - speakerName: "\uD558\uC6B0\uC2A4 \uB9C8\uC2A4\uD130"
    dialogue: "\uADF8\uB7F0\uB370 \uC774\uAC74, \uCD94\uCD9C\uD574\uC11C \uD314 \uC218
      \uC788\uC5B4\uC694."
    characterSprite: {fileID: 21300000, guid: 8af7b5ad94be1ba41b30a074b4655a52, type: 3}
    voiceClip: {fileID: 8300000, guid: 04fb25806cd2e754e8f5d76e5ec5e020, type: 3}
    hasChoices: 0
    choices:
    - choiceText: 
      responseLines:
      - speakerName: 
        dialogue: 
        characterSprite: {fileID: 0}
        voiceClip: {fileID: 0}
    - choiceText: 
      responseLines:
      - speakerName: 
        dialogue: 
        characterSprite: {fileID: 0}
        voiceClip: {fileID: 0}
    - choiceText: 
      responseLines:
      - speakerName: 
        dialogue: 
        characterSprite: {fileID: 0}
        voiceClip: {fileID: 0}
  - speakerName: "\uD558\uC6B0\uC2A4 \uB9C8\uC2A4\uD130"
    dialogue: "\uC774\uAC8C \uC774 \uC2DC\uB300\uC758 \uC0C8\uB85C\uC6B4 \uD654\uD3D0\uC778
      \u2014 LUX\uC608\uC694. "
    characterSprite: {fileID: 21300000, guid: 8af7b5ad94be1ba41b30a074b4655a52, type: 3}
    voiceClip: {fileID: 8300000, guid: e8107432446e1ef4cb48c32a0ed645e3, type: 3}
    hasChoices: 1
    choices:
    - choiceText: "\uC774\uBBF8 \uC54C\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
      responseLines:
      - speakerName: "\uD558\uC6B0\uC2A4 \uB9C8\uC2A4\uD130"
        dialogue: "\uB2F9\uC5F0\uD788 \uC54C\uACA0\uC8E0. \uADF8\uB798\uC11C \uC5EC\uAE30
          \uC788\uB294 \uAC70\uB2C8\uAE4C."
        characterSprite: {fileID: 21300000, guid: 8af7b5ad94be1ba41b30a074b4655a52, type: 3}
        voiceClip: {fileID: 8300000, guid: 5c45fac181f1df04da0c67ab7da16046, type: 3}
    - choiceText: "\uCC98\uC74C \uB4E3\uB294 \uC598\uAE30\uC785\uB2C8\uB2E4."
      responseLines:
      - speakerName: "\uD558\uC6B0\uC2A4 \uB9C8\uC2A4\uD130"
        dialogue: "\uC5B4\uBA38, \uC9C4\uC9DC? \uADC0\uC5FD\uB124. \uACC4\uC18D \uB4E4\uC5B4\uC694,
          \uADF8\uB7FC."
        characterSprite: {fileID: 0}
        voiceClip: {fileID: 8300000, guid: 88251ee6675a43d4188031a744f74b62, type: 3}
    - choiceText: "\uC2E4\uB840\uC9C0\uB9CC, \uC544\uB984\uB2E4\uC6B0\uC2ED\uB2C8\uB2E4."
      responseLines:
      - speakerName: "\uD558\uC6B0\uC2A4 \uB9C8\uC2A4\uD130"
        dialogue: "\uC5B4\uBA38, \uAC11\uC790\uAE30? \uC5B4\uCA0C\uB4E0 \uACE0\uB9C8\uC6CC\uC694.
          \uACC4\uC18D \uC560\uAE30\uD560\uAC8C\uC694."
        characterSprite: {fileID: 21300000, guid: 8af7b5ad94be1ba41b30a074b4655a52, type: 3}
        voiceClip: {fileID: 8300000, guid: 4bc500df84aa4fc4db8ef8365a1284c4, type: 3}
  - speakerName: "\uD558\uC6B0\uC2A4 \uB9C8\uC2A4\uD130"
    dialogue: "\uAC00\uB09C\uD55C \uC0AC\uB78C\uB4E4\uC740 LUX\uB97C \uD314\uC544\uC694.
      \uC0B4\uAE30 \uC704\uD574\uC11C. "
    characterSprite: {fileID: 21300000, guid: 8af7b5ad94be1ba41b30a074b4655a52, type: 3}
    voiceClip: {fileID: 8300000, guid: 3aa12a672fe6eb943acc59f4e8416f9d, type: 3}
