          characterSprite: {fileID: 0}
          voiceClip: {fileID: 0}
    - speakerName: "\uD558\uC6B0\uC2A4 \uB9C8\uC2A4\uD130"
      dialogue: "\uBE7C\uC557\uAE38 \uD589\uC6B4\uC774 \uC5C6\uC73C\uBA74 \uB450\uB835\uC9C0
        \uC54A\uC796\uC544\uC694. \uADF8\uB798\uC11C \uCF54\uB4DC\uBA85\uB3C4, \uC81C\uB85C. "
      characterSprite: {fileID: 21300000, guid: 8af7b5ad94be1ba41b30a074b4655a52, type: 3}
      voiceClip: {fileID: 8300000, guid: eeeb7094d4b787041abb5fc8458f2107, type: 3}
