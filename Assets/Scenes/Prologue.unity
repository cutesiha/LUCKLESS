    - speakerName: "\uD558\uC6B0\uC2A4 \uB9C8\uC2A4\uD130"
      dialogue: "\uD574\uC57C\uD560 \uC77C\uC740 \uB531 \uC138 \uAC00\uC9C0. \n\uBC29\uD574\uD558\uB294
        \uC790 \uCC98\uB9AC, \uBBF8\uB0A9\uC790 \uAC15\uC81C \uC218\uAC70, \uACBD\uC7C1\uC790
        \uC81C\uAC70. "
      characterSprite: {fileID: 21300000, guid: 8af7b5ad94be1ba41b30a074b4655a52, type: 3}
      voiceClip: {fileID: 8300000, guid: c5d4adc123103cb4ba1cd432de9e4033, type: 3}
      hasChoices: 0
      choices:
      - choiceText: 
        responseLines:
        - speakerName: 
          dialogue: 
          characterSprite: {fileID: 0}
          voiceClip: {fileID: 0}
      - choiceText: 
        responseLines:
        - speakerName: 
          dialogue: 
          characterSprite: {fileID: 0}
          voiceClip: {fileID: 0}
      - choiceText: 
        responseLines:
        - speakerName: 
          dialogue: 
          characterSprite: {fileID: 0}
          voiceClip: {fileID: 0}
    - speakerName: "\uD558\uC6B0\uC2A4 \uB9C8\uC2A4\uD130"
      dialogue: "\uC5B4\uB54C\uC694, \uAC04\uB2E8\uD558\uC8E0? "
      characterSprite: {fileID: 21300000, guid: 8af7b5ad94be1ba41b30a074b4655a52, type: 3}
      voiceClip: {fileID: 8300000, guid: 1593390370d5d69449af422810df19fb, type: 3}
      hasChoices: 1
      choices:
      - choiceText: "\uB124. \uB9E1\uACA8\uB9CC \uC8FC\uC2DC\uC8E0."
        responseLines:
        - speakerName: "\uD558\uC6B0\uC2A4 \uB9C8\uC2A4\uD130"
          dialogue: "\uC5ED\uC2DC \uBBFF\uC74C\uC9C1\uC2A4\uB7FD\uAD70\uC694! \uB9C8\uC74C\uC5D0
            \uB4E4\uC5B4\uC694."
          characterSprite: {fileID: 21300000, guid: 8af7b5ad94be1ba41b30a074b4655a52, type: 3}
          voiceClip: {fileID: 8300000, guid: bf5a8fdd0139dbd438c680ff3de7d187, type: 3}
      - choiceText: "\uC544\uB1E8. \uD798\uB4E4 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4."
        responseLines:
        - speakerName: "\uD558\uC6B0\uC2A4 \uB9C8\uC2A4\uD130"
          dialogue: "\uC18C\uC6A9 \uC5C6\uC5B4\uC694. \uB2F9\uC2E0\uC5D0\uAC8C \uC120\uD0DD\uC9C0\uB294
            \uC5C6\uB2F5\uB2C8\uB2E4."
          characterSprite: {fileID: 21300000, guid: 8af7b5ad94be1ba41b30a074b4655a52, type: 3}
          voiceClip: {fileID: 8300000, guid: b685482ccb6c2364cab6f707c0f0d726, type: 3}
    - speakerName: "\uD558\uC6B0\uC2A4 \uB9C8\uC2A4\uD130"
      dialogue: "\uADF8\uB9AC\uACE0 \uB2F9\uC2E0\uC740 \uD2B9\uBCC4\uD574\uC694.
        \uB7ED\uC2A4 \uC218\uCE58\uAC00 \u2014 0. \n\uD3EC\uB974\uD22C\uB098 \uCF54\uC5B4\uAC00
        \uC791\uB3D9\uC744 \uD558\uC9C0 \uC54A\uC8E0. "
      characterSprite: {fileID: 21300000, guid: 8af7b5ad94be1ba41b30a074b4655a52, type: 3}
      voiceClip: {fileID: 8300000, guid: 25a8c32fe03fdf84da77d86ac366a0d2, type: 3}
      hasChoices: 0
      choices:
      - choiceText: 
        responseLines:
        - speakerName: 
